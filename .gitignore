# ================================================================
# Field Marketing System — .gitignore
# ================================================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Environment variables (SANGAT PENTING — jangan commit secrets!)
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ================================================================
# Next.js (Web Dashboard)
# ================================================================
.next/
out/
build/
.vercel

# ================================================================
# Expo / React Native (Mobile App)
# ================================================================
.expo/
dist/
web-build/
expo-env.d.ts
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Generated native folders (Expo)
ios/
android/

# Metro
.metro-health-check*

# ================================================================
# TypeScript
# ================================================================
*.tsbuildinfo
next-env.d.ts

# ================================================================
# IDE / Editor
# ================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ================================================================
# macOS / Windows / Linux
# ================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.lnk

# ================================================================
# Logs
# ================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ================================================================
# Cache & Build Tools
# ================================================================
.eslintcache
.turbo/
.cache/

# ================================================================
# Supabase
# ================================================================
supabase/.temp/

# ================================================================
# Test Coverage
# ================================================================
coverage/
.nyc_output/

# ================================================================
# Lock files (opsional — uncomment jika ingin ignore)
